  "competitors": {
    "cloudinary": {
      "name": "Cloudinary",
      "slug": "cloudinary",
      "description": "Cloudinary pioneered cloud media management, but its proprietary model means usage-based pricing starting at $89/month and no way out once you're in. Openinary delivers the same powerful transformations, auto-format, and CDN delivery — fully open source, self-hostable, and designed so you never lose control of your media stack.",
      "website": "https://cloudinary.com",
      "founded": "2012",
      "headquarter": "Santa Clara, CA"
    },
    "imagekit": {
      "name": "ImageKit",
      "slug": "imagekit",
      "description": "ImageKit offers solid real-time optimization, but it's a closed platform — no self-hosting, no storage freedom, and $49/month to get started. Openinary gives you the same URL-based transformations and global delivery, with the flexibility to deploy on your own infrastructure using any S3-compatible storage.",
      "website": "https://imagekit.io",
      "founded": "2016",
      "headquarter": "San Francisco, CA"
    },
    "uploadcare": {
      "name": "Uploadcare",
      "slug": "uploadcare",
      "description": "Uploadcare keeps things simple, but that simplicity comes with trade-offs — limited upload quotas, fewer transformations, and no path to self-hosting. Openinary offers a more complete image processing pipeline with full storage flexibility, and it's entirely free when you run it on your own infrastructure.",
      "website": "https://uploadcare.com",
      "founded": "2011",
      "headquarter": "Amsterdam, Netherlands"
    },
    "imgix": {
      "name": "imgix",
      "slug": "imgix",
      "description": "imgix is known for powerful URL-based processing, but at $100/month with no free tier, it's built for enterprises willing to pay a premium for a closed platform. Openinary matches that transformation power and bring-your-own-storage flexibility — with full open-source transparency and zero extra cost when self-hosted.",
      "website": "https://imgix.com",
      "founded": "2011",
      "headquarter": "San Francisco, CA"
    },
    "thumbor": {
      "name": "Thumbor",
      "slug": "thumbor",
      "description": "Thumbor proved that open-source image processing is viable, but it stops there — no built-in CDN, no video support, and a complex setup process. Openinary picks up where Thumbor left off, adding edge delivery, a modern REST API, one-command Docker deployment, and a roadmap that includes video and AI transformations.",
      "website": "https://www.thumbor.org",
      "founded": "2011",
      "headquarter": "Rio de Janeiro, Brazil"
    },
    "cloudimage": {
      "name": "Cloudimage",
      "slug": "cloudimage",
      "description": "Cloudimage handles image optimization and CDN delivery well, but as a proprietary SaaS at $49/month, you're renting someone else's pipeline with no visibility into it. Openinary gives you the same capabilities with full source code access, self-hosting freedom, and complete control over your media workflow.",
      "website": "https://www.cloudimage.io",
      "founded": "2015",
      "headquarter": "Paris, France"
    },
    "gumlet": {
      "name": "Gumlet",
      "slug": "gumlet",
      "description": "Gumlet supports S3 origins and competitive pricing, but it's still a closed platform where your media pipeline depends on a third party. Openinary takes the same S3-native approach further — fully open source, deployable anywhere with Docker, and unlimited when self-hosted. Your media, your rules.",
      "website": "https://www.gumlet.com",
      "founded": "2019",
      "headquarter": "Singapore"
    }
  },
  "openinary": {
    "name": "Openinary",
    "tagline": "Open-source, self-hostable alternative to Cloudinary",
    "highlights": [
      "Open source under AGPL-3.0 license",
      "Self-host on your own infrastructure",
      "No vendor lock-in, own your data",
      "Works with S3, R2, MinIO and any S3-compatible storage",
      "Free forever when self-hosted"
    ]
  }
